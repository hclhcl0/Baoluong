# Biến môi trường - GỬI EMAIL BÁO LƯƠNG
# KHÔNG commit file này lên Git!
# Thêm .env.local vào .gitignore

# ========== GMAIL ACCOUNT POOL ==========
# Định dạng: GMAIL_POOL=user1@gmail.com:password1,user2@gmail.com:password2
# App Password: vào Google Account > Security > 2-Step Verification > App passwords
# Mỗi App Password có dạng: xxxx xxxx xxxx xxxx (16 ký tự, không có khoảng trắng)
GMAIL_POOL=email1@gmail.com:app_password_1,email2@gmail.com:app_password_2

# ========== CẤU HÌNH GỬI EMAIL ==========
# Tiêu đề email mặc định
EMAIL_SUBJECT=Thông báo lương quý - CDC Cà Mau

# Số email gửi mỗi batch (khuyến nghị: 10)
EMAIL_BATCH_SIZE=10

# Thời gian nghỉ giữa các batch (milliseconds, khuyến nghị: 2000)
EMAIL_BATCH_DELAY_MS=2000
